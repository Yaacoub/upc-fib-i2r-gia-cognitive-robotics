sp {elaborate*state*structure
    (state <s> ^superstate nil)
-->
    (<s> ^environment <env>)
}


sp {propose*init-environment
    (state <s> ^superstate nil)
    -(<s> ^name cognitive-robotics)
-->
    (<s> ^operator <o> + >)
    (<o> ^name init-environment)
}


sp {apply*init-environment*base
    (state <s> ^operator.name init-environment
        -^name cognitive-robotics)
-->
    (<s> ^name cognitive-robotics)
}



# ==================================================
# ONTOLOGY CATEGORY: AGENT
# ==================================================

sp {apply*init-environment*agent_01
    (state <s> ^operator.name init-environment
        ^environment <env>
        -^name cognitive-robotics)
-->
    (<env> ^entity <e>)
    (<e> ^id agent_01
        ^isatlocation loc_0_0
        ^type agent
        ^type namedindividual
    )
}


