sp {apply*init-environment*containsobject
    (state <s> ^operator.name init-environment
        ^environment <env>
        -^name cognitive-robotics)
-->
    (<env> ^entity <e>)
    (<e> ^id containsobject
        ^inverseof isatlocation
        ^type objectproperty
    )
}

sp {apply*init-environment*isatlocation
    (state <s> ^operator.name init-environment
        ^environment <env>
        -^name cognitive-robotics)
-->
    (<env> ^entity <e>)
    (<e> ^id isatlocation
        ^domain n86cba51865af4d489b3669d1faa9cdc6
        ^range gridlocation
        ^type functionalproperty
        ^type objectproperty
    )
}

